# CatClaw environment variables
# Copy this file to .env and fill in your values.
# These are read by the gateway at startup.

# Discord bot token (from Discord Developer Portal → Bot → Token)
# CATCLAW_DISCORD_TOKEN=your_discord_bot_token_here

# Telegram bot token (from @BotFather)
# CATCLAW_TELEGRAM_TOKEN=your_telegram_bot_token_here
